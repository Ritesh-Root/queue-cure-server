# Port the server listens on (frontend defaults to 3000)
PORT=3000

# Optional. Leave empty for an open demo (the provided frontend sends no key).
# If set, reception clients must include { key: "<value>" } in their reception:join payload.
RECEPTION_KEY=

# Comma-separated CORS allow-list. Vite dev server is 5173.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Where queue state is persisted (synchronous JSON snapshot).
DATA_FILE=./data/queue.json

# How often (ms) the server re-broadcasts state so wait estimates stay fresh.
HEARTBEAT_MS=10000

# Seed average consultation time (minutes) before real data accumulates.
AVG_DEFAULT_MINUTES=8
